-- 1. Users Table
CREATE TABLE IF NOT EXISTS public.users (
    id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
    user_email TEXT UNIQUE NOT NULL,
    user_hash_password TEXT NOT NULL,
    user_first_name TEXT DEFAULT '',
    user_last_name TEXT DEFAULT '',
    user_phone_number TEXT,
    is_clinician BOOLEAN DEFAULT FALSE,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT timezone('utc'::text, now()) NOT NULL
);

-- 2. Invasive Table (PSA Data)
CREATE TABLE IF NOT EXISTS public.invasive_table (
    id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    user_email TEXT,
    result NUMERIC,
    age NUMERIC,
    "psa_(ng/ml)" NUMERIC,
    "body_weight_(kg)" NUMERIC,
    "height_(cm)" NUMERIC,
    family_history_prostate_cancer NUMERIC,
    educational_background NUMERIC,
    hypertension NUMERIC,
    heart_disease NUMERIC,
    cerebro_vascular_disease NUMERIC,
    hyperlipidemia NUMERIC,
    diabetes_melitus NUMERIC,
    renal_disease NUMERIC,
    other_cancer NUMERIC,
    other_disease NUMERIC,
    region_rural NUMERIC,
    race_c NUMERIC,
    race_i NUMERIC,
    race_m NUMERIC,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT timezone('utc'::text, now()) NOT NULL
);

-- 3. Prediction Results Table (FTIR Data)
CREATE TABLE IF NOT EXISTS public.prediction_results (
    id BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    user_email TEXT,
    modality TEXT,
    prediction NUMERIC,
    probability NUMERIC,
    csv_data TEXT,
    latency_ms NUMERIC,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT timezone('utc'::text, now()) NOT NULL
);
